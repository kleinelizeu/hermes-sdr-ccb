[Unit]
Description=Cloudflare Tunnel para o webhook do Hermes SDR (porta 8644)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/cloudflared tunnel --no-autoupdate --url http://localhost:8644 --logfile /var/log/cloudflared-sdr.log
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
